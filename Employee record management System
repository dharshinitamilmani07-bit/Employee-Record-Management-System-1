from abc import ABC, abstractmethod
class Person(ABC):
    def display(self):
        pass
class Employee(Person):
    def __init__(self,emp_id,name,department,designation,experience,salary,bonus):
        self.__emp_id=emp_id
        self.__name=name
        self.__department=department
        self.__designation=designation
        self.__experience=experience
        self.__salary=salary
        self.__bonus=bonus
    def get_id(self):
        return self.__emp_id
    def get_name(self):
        return self.__name
    def get_salary(self):
        return self.__salary
    def get_bonus(self):
        return self.__bonus
    def get_experience(self):
        return self.__experience
    def set_salary(self,salary):
        self.__salary=salary
    def set_bonus(self,bonus):
        self.__bonus=bonus
    def set_experience(self,experience):
        self.__experience=experience
    def display(self):
        total=self.__salary+self.__bonus
        print("\n----- Employee Details -----")
        print("Employee ID :",self.__emp_id)
        print("Name        :",self.__name)
        print("Department  :",self.__department)
        print("Designation :",self.__designation)
        print("Experience  :",self.__experience, "Years")
        print("Salary      :",self.__salary)
        print("Bonus       :",self.__bonus)
        print("Total Salary:",total)
emp_list=[]
while True:
    print("\n===== Employee Record Management System =====")
